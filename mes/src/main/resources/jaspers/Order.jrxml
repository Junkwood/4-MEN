	<parameter name="orderCode" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
       find_prod_name(d.prod_code) 제품명,
       d.order_quantity 주문량,
       o.registration_date 등록일자,
       o.due_date 납기일자,
       find_client_name(o.client_code) 업체명,
       find_emp_name(o.emp_code) 담당자,
       o.order_code 주문코드,
       d.order_price 단가,
       d.order_quantity*d.order_price 총주문금액
FROM order_detail d JOIN orders o 
                    ON (o.order_code=d.order_code)
WHERE o.order_code=$P{orderCode} ]]>
	</queryString>
