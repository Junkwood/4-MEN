		</field>
	</subDataset>
	<parameter name="p_mat_order_code" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT  mat_order_code AS 발주번호,
            order_name AS 발주명,
            find_emp_name(emp_code) AS 담당자,
            order_date AS 등록일자
FROM   mat_order
WHERE mat_order_code = $P{p_mat_order_code}]]>
	</queryString>
