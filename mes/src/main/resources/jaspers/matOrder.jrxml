	<subDataset name="mat order detail" uuid="522926f1-e714-4cce-b351-65dccc1c54bc">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mes"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="c_mat_order_code" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT md.mat_order_detail_code "발주상세코드",
           mat.mat_name 자재명,
           mat.mat_class 분류,
           mat.standard 규격,
           mat.unit 단위,
           md.client_name 거래처,
           md.quantity 수량,
           md.delivery_date 납기일자
FROM  mat_order_detail md JOIN mat_common mat
                                          ON (md.mat_code = mat.mat_code)
WHERE  md.mat_order_code = $P{c_mat_order_code}]]>
		</queryString>
		<field name="발주상세코드" class="java.lang.String">
